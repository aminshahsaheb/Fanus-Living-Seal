# fanus-engine/wound/wound_engine.py

from .wound_types import WoundEvent

class WoundEngine:

    def __init__(self, ledger):
        self.ledger = ledger

    def record_fi_error(self, context, severity=0.5):

        event = WoundEvent(
            type="FI_ERROR",
            severity=severity,
            context=context
        )

        self.ledger.append(event)
        return event

    def record_drift_spike(self, drift_score, context):

        severity = min(1.0, drift_score)

        event = WoundEvent(
            type="DRIFT_SPIKE",
            severity=severity,
            context=context
        )

        self.ledger.append(event)
        return event
