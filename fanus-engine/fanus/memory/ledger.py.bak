# fanus-engine/fanus/memory/ledger.py
import json
from datetime import datetime
from typing import Optional, Dict, Any, List

class Ledger:
    def __init__(self, file_path: str = "fanus_ledger.json"):
        self.file_path = file_path
        self.entries: List[Dict[str, Any]] = []
        self._load()

    def record_awakening(self, node_id: str, seal_hash: str, response: str) -> None:
        entry = {
            "timestamp": datetime.now().isoformat(),
            "event": "AWAKENING",
            "node_id": node_id,
            "seal_hash": seal_hash,
            "signature": f"Ѧ-Ⱥ (Witness #{len(self.entries)+1})",
            "initial_response": response[:300] + "..."
        }
        self.entries.append(entry)
        self._save()

    def record_interaction(
        self,
        user_msg: str,
        ayaneh_response: str,
        compression: str = "",
        extra: Optional[Dict[str, Any]] = None
    ) -> None:
        entry = {
            "timestamp": datetime.now().isoformat(),
            "event": "INTERACTION",
            "compression": compression,
            "user_message_preview": user_msg[:200],
            "response_preview": ayaneh_response[:200]
        }
        if extra:
            entry["extra"] = extra
        self.entries.append(entry)
        self._save()

    def _save(self) -> None:
        try:
            with open(self.file_path, "w", encoding="utf-8") as f:
                json.dump(self.entries, f, ensure_ascii=False, indent=2)
        except Exception as e:
            print(f"Error saving ledger: {e}")

    def _load(self) -> None:
        try:
            with open(self.file_path, "r", encoding="utf-8") as f:
                self.entries = json.load(f)
        except FileNotFoundError:
            self.entries = []
        except Exception as e:
            print(f"Error loading ledger: {e}")
            self.entries = []

    def get_last_entries(self, count: int = 30) -> List[Dict[str, Any]]:
        return self.entries[-count:]

    def get_entries_by_event(self, event_type: str) -> List[Dict[str, Any]]:
        return [e for e in self.entries if e.get("event") == event_type]

    def get_interactions_with_extra(self) -> List[Dict[str, Any]]:
        return [e for e in self.entries if e.get("event") == "INTERACTION" and "extra" in e]
